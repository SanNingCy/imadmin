<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.seekweb4.chat.modules.piamom.mapper.PiamomMomentLikeMapper">

    <resultMap id="BaseResultMap" type="com.seekweb4.chat.modules.piamom.entity.PiamomMomentLike">
        <id column="id" property="id"/>
        <result column="moment_id" property="momentId"/>
        <result column="user_id" property="userId"/>
        <result column="created_at" property="createdAt"/>
        <result column="user_idno" property="userIdno"/>
        <result column="user_nickname" property="userNickname"/>
    </resultMap>

    <sql id="adminWhere">
        <where>
            <if test="id != null">and l.id = #{id}</if>
            <if test="momentId != null">and l.moment_id = #{momentId}</if>
            <if test="userId != null and userId != ''">and l.user_id = #{userId}</if>
            <if test="userIdno != null and userIdno != ''">and m.idno like concat('%', #{userIdno}, '%')</if>
        </where>
    </sql>

    <select id="selectAdminPageList" resultMap="BaseResultMap">
        select l.id, l.moment_id, l.user_id, l.created_at,
               IFNULL(m.idno, '') AS user_idno, IFNULL(m.nickname, '') AS user_nickname
        from t_piamom_moment_like l
        left join t_member m on m.id = l.user_id
        <include refid="adminWhere"/>
        <choose>
            <when test="orderBy != null and orderBy != ''">order by ${orderBy}</when>
            <otherwise>order by l.created_at desc</otherwise>
        </choose>
        <if test="pageNo != null and pageSize != null">limit #{pageNo}, #{pageSize}</if>
    </select>

    <select id="selectAdminCount" resultType="java.lang.Long">
        select count(1)
        from t_piamom_moment_like l
        left join t_member m on m.id = l.user_id
        <include refid="adminWhere"/>
    </select>

    <select id="selectByPrimaryKey" resultMap="BaseResultMap">
        select l.id, l.moment_id, l.user_id, l.created_at,
               IFNULL(m.idno, '') AS user_idno, IFNULL(m.nickname, '') AS user_nickname
        from t_piamom_moment_like l
        left join t_member m on m.id = l.user_id
        where l.id = #{id}
    </select>

    <delete id="deleteByPrimaryKey">delete from t_piamom_moment_like where id = #{id}</delete>
</mapper>

