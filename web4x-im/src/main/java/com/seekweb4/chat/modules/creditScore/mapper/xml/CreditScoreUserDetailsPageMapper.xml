<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.seekweb4.chat.modules.creditScore.mapper.CreditScoreUserDetailsPageMapper">

    <resultMap id="UserDetailsPageResultMap" type="com.seekweb4.chat.modules.creditScore.vo.CreditScoreUserDetailsVo">
        <result column="userId" property="userId"/>
        <result column="idno" property="idno"/>
        <result column="lianghao" property="lianghao"/>
        <result column="totalCreditScore" property="totalCreditScore"/>
    </resultMap>

    <sql id="UserDetailsPage_Columns">
        d.user_id AS userId,
        m.idno AS idno,
        m.lianghao AS lianghao,
        d.credit_score AS totalCreditScore
    </sql>

    <select id="selectPageList" resultMap="UserDetailsPageResultMap">
        SELECT
            <include refid="UserDetailsPage_Columns"/>
        FROM t_member_details d
        LEFT JOIN t_member m ON m.id = d.user_id
        <where>
            d.is_deleted = 0
            <if test="userId != null and userId != ''">
                AND d.user_id = #{userId}
            </if>
            <if test="idno != null and idno != ''">
                AND m.idno LIKE CONCAT('%', #{idno}, '%')
            </if>
            <if test="lianghao != null and lianghao != ''">
                AND m.lianghao LIKE CONCAT('%', #{lianghao}, '%')
            </if>
        </where>
        <if test="orderBy != null and orderBy != ''">
            ORDER BY ${orderBy}
        </if>
        <if test="orderBy == null or orderBy == ''">
            ORDER BY d.update_time DESC, d.id DESC
        </if>
        <if test="pageNo != null and pageSize != null">
            LIMIT #{pageNo}, #{pageSize}
        </if>
    </select>

    <select id="selectCount" resultType="java.lang.Long">
        SELECT COUNT(1)
        FROM t_member_details d
        LEFT JOIN t_member m ON m.id = d.user_id
        <where>
            d.is_deleted = 0
            <if test="userId != null and userId != ''">
                AND d.user_id = #{userId}
            </if>
            <if test="idno != null and idno != ''">
                AND m.idno LIKE CONCAT('%', #{idno}, '%')
            </if>
            <if test="lianghao != null and lianghao != ''">
                AND m.lianghao LIKE CONCAT('%', #{lianghao}, '%')
            </if>
        </where>
    </select>

    <select id="selectDetailByUserId" resultMap="UserDetailsPageResultMap">
        SELECT
            <include refid="UserDetailsPage_Columns"/>
        FROM t_member_details d
        LEFT JOIN t_member m ON m.id = d.user_id
        <where>
            d.is_deleted = 0
            AND d.user_id = #{userId}
        </where>
        LIMIT 1
    </select>

</mapper>

