<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.seekweb4.chat.modules.exchangeApply.mapper.ExchangeApplyMapper">

    <resultMap id="BaseResultMap" type="com.seekweb4.chat.modules.exchangeApply.entity.ExchangeApply">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="transaction_number" property="transactionNumber"/>
        <result column="pretty_number" property="prettyNumber"/>
        <result column="bridge_voucher" property="bridgeVoucher"/>
        <result column="bridge_user_address" property="bridgeUserAddress"/>
        <result column="status" property="status"/>
        <result column="fail_reason" property="failReason"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="create_by" property="createBy"/>
        <result column="update_by" property="updateBy"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, user_id, transaction_number, pretty_number, bridge_voucher, bridge_user_address,
        status, fail_reason, create_time, update_time, create_by, update_by
    </sql>

    <!-- 根据主键查询 -->
    <select id="selectByPrimaryKey" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM t_exchange_apply
        WHERE id = #{id}
    </select>

    <!-- 后台管理 - 分页查询靓号兑换申请 -->
    <select id="selectAdminPageList" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM t_exchange_apply
        <where>
            <if test="id != null">
                AND id = #{id}
            </if>
            <if test="userId != null and userId != ''">
                AND user_id = #{userId}
            </if>
            <if test="transactionNumber != null and transactionNumber != ''">
                AND transaction_number LIKE CONCAT('%', #{transactionNumber}, '%')
            </if>
            <if test="prettyNumber != null and prettyNumber != ''">
                AND pretty_number LIKE CONCAT('%', #{prettyNumber}, '%')
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
            <if test="createTimeStart != null">
                AND create_time &gt;= #{createTimeStart}
            </if>
            <if test="createTimeEnd != null">
                AND create_time &lt;= #{createTimeEnd}
            </if>
        </where>
        <if test="orderBy != null and orderBy != ''">
            ORDER BY ${orderBy}
        </if>
        <if test="orderBy == null or orderBy == ''">
            ORDER BY create_time DESC
        </if>
        <if test="pageNo != null and pageSize != null">
            LIMIT #{pageNo}, #{pageSize}
        </if>
    </select>

    <!-- 后台管理 - 统计靓号兑换申请总数 -->
    <select id="selectAdminCount" resultType="java.lang.Long">
        SELECT COUNT(1)
        FROM t_exchange_apply
        <where>
            <if test="id != null">
                AND id = #{id}
            </if>
            <if test="userId != null and userId != ''">
                AND user_id = #{userId}
            </if>
            <if test="transactionNumber != null and transactionNumber != ''">
                AND transaction_number LIKE CONCAT('%', #{transactionNumber}, '%')
            </if>
            <if test="prettyNumber != null and prettyNumber != ''">
                AND pretty_number LIKE CONCAT('%', #{prettyNumber}, '%')
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
            <if test="createTimeStart != null">
                AND create_time &gt;= #{createTimeStart}
            </if>
            <if test="createTimeEnd != null">
                AND create_time &lt;= #{createTimeEnd}
            </if>
        </where>
    </select>
</mapper>
