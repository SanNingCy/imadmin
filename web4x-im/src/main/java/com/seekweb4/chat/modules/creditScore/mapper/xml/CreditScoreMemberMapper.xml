<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.seekweb4.chat.modules.creditScore.mapper.CreditScoreMemberMapper">


    <select id="selectMemberInfoByUserId" resultType="com.seekweb4.chat.modules.creditScore.vo.CreditScoreMemberInfoVo">
        SELECT
            idno AS idno,
            lianghao AS lianghao,
            isvip AS isvip
        FROM t_member
        WHERE id = #{userId}
        LIMIT 1
    </select>

