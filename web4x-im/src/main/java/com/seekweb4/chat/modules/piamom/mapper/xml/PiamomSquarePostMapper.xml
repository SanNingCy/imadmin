<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.seekweb4.chat.modules.piamom.mapper.PiamomSquarePostMapper">

    <resultMap id="BaseResultMap" type="com.seekweb4.chat.modules.piamom.entity.PiamomSquarePost">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="content" property="content"/>
        <result column="image_urls" property="imageUrls"/>
        <result column="video" property="video"/>
        <result column="type" property="type"/>
        <result column="odic_stake" property="odicStake"/>
        <result column="odic_stake_status" property="odicStakeStatus"/>
        <result column="stake_refund_time" property="stakeRefundTime"/>
        <result column="view_count" property="viewCount"/>
        <result column="like_count" property="likeCount"/>
        <result column="comment_count" property="commentCount"/>
        <result column="quote_count" property="quoteCount"/>
        <result column="comment_gate_flags" property="commentGateFlags"/>
        <result column="comment_credit_min" property="commentCreditMin"/>
        <result column="is_top" property="isTop"/>
        <result column="top_time" property="topTime"/>
        <result column="quote_ref_type" property="quoteRefType"/>
        <result column="quote_ref_id" property="quoteRefId"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="status" property="status"/>
        <result column="user_idno" property="userIdno"/>
        <result column="user_nickname" property="userNickname"/>
    </resultMap>

    <sql id="adminSelectColumns">
        a.id, a.user_id, a.content, a.image_urls, a.video, a.type, a.odic_stake, a.odic_stake_status,
        a.stake_refund_time, a.view_count, a.like_count, a.comment_count, a.quote_count, a.comment_gate_flags,
        a.comment_credit_min, a.is_top, a.top_time, a.quote_ref_type, a.quote_ref_id,
        a.created_at, a.updated_at, a.status,
        IFNULL(m.idno, '') AS user_idno, IFNULL(m.nickname, '') AS user_nickname
    </sql>

    <sql id="adminWhere">
        <where>
            <if test="id != null">and a.id = #{id}</if>
            <if test="userId != null and userId != ''">and a.user_id = #{userId}</if>
            <if test="userIdno != null and userIdno != ''">and m.idno like concat('%', #{userIdno}, '%')</if>
            <if test="isTop != null">and a.is_top = #{isTop}</if>
            <if test="type != null and type != ''">and a.type = #{type}</if>
            <if test="odicStakeStatus != null">and a.odic_stake_status = #{odicStakeStatus}</if>
            <if test="content != null and content != ''">and a.content like concat('%', #{content}, '%')</if>
        </where>
    </sql>

    <select id="selectAdminPageList" resultMap="BaseResultMap">
        select <include refid="adminSelectColumns"/>
        from t_piamom_square_post a
        left join t_member m on m.id = a.user_id
        <include refid="adminWhere"/>
        <choose>
            <when test="orderBy != null and orderBy != ''">order by ${orderBy}</when>
            <otherwise>order by a.is_top desc, a.top_time desc, a.created_at desc</otherwise>
        </choose>
        <if test="pageNo != null and pageSize != null">limit #{pageNo}, #{pageSize}</if>
    </select>

    <select id="selectAdminCount" resultType="java.lang.Long">
        select count(1) from t_piamom_square_post a
        left join t_member m on m.id = a.user_id
        <include refid="adminWhere"/>
    </select>

    <select id="selectByPrimaryKey" resultMap="BaseResultMap">
        select <include refid="adminSelectColumns"/>
        from t_piamom_square_post a
        left join t_member m on m.id = a.user_id
        where a.id = #{id}
    </select>

    <delete id="deleteByPrimaryKey">delete from t_piamom_square_post where id = #{id}</delete>

    <update id="updateTop">
        update t_piamom_square_post
        set is_top = #{isTop},
            top_time = case when #{isTop} = 1 then now() else null end,
            updated_at = now()
        where id = #{id}
    </update>

    <update id="updateByPrimaryKeySelective">
        update t_piamom_square_post
        <set>
            <if test="odicStakeStatus != null">odic_stake_status = #{odicStakeStatus},</if>
            <if test="stakeRefundTime != null">stake_refund_time = #{stakeRefundTime},</if>
            updated_at = now()
        </set>
        where id = #{id}
    </update>

    <update id="updateStakeStatusIf">
        update t_piamom_square_post
        set odic_stake_status = #{toStatus},
            updated_at = now()
        where id = #{id}
          and odic_stake_status = #{fromStatus}
    </update>

    <update id="hideByPrimaryKey">
        update t_piamom_square_post
        set status = 0,
            is_top = 0,
            top_time = null,
            updated_at = now()
        where id = #{id}
    </update>
</mapper>
