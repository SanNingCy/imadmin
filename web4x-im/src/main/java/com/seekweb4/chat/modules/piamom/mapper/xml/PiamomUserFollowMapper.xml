<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.seekweb4.chat.modules.piamom.mapper.PiamomUserFollowMapper">

    <resultMap id="BaseResultMap" type="com.seekweb4.chat.modules.piamom.entity.PiamomUserFollow">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="follower_id" property="followerId"/>
        <result column="status" property="status"/>
        <result column="created_at" property="createdAt"/>
        <result column="user_idno" property="userIdno"/>
        <result column="user_nickname" property="userNickname"/>
        <result column="follower_idno" property="followerIdno"/>
        <result column="follower_nickname" property="followerNickname"/>
    </resultMap>

    <sql id="adminWhere">
        <where>
            <if test="id != null">and f.id = #{id}</if>
            <if test="userId != null and userId != ''">and f.user_id = #{userId}</if>
            <if test="userIdno != null and userIdno != ''">and um.idno like concat('%', #{userIdno}, '%')</if>
            <if test="followerId != null and followerId != ''">and f.follower_id = #{followerId}</if>
            <if test="followerIdno != null and followerIdno != ''">and fm.idno like concat('%', #{followerIdno}, '%')</if>
            <if test="status != null">and f.status = #{status}</if>
        </where>
    </sql>

    <select id="selectAdminPageList" resultMap="BaseResultMap">
        select f.id, f.user_id, f.follower_id, f.status, f.created_at,
               IFNULL(um.idno, '') AS user_idno, IFNULL(um.nickname, '') AS user_nickname,
               IFNULL(fm.idno, '') AS follower_idno, IFNULL(fm.nickname, '') AS follower_nickname
        from t_piamom_user_follow f
        left join t_member um on um.id = f.user_id
        left join t_member fm on fm.id = f.follower_id
        <include refid="adminWhere"/>
        <choose>
            <when test="orderBy != null and orderBy != ''">order by ${orderBy}</when>
            <otherwise>order by f.created_at desc</otherwise>
        </choose>
        <if test="pageNo != null and pageSize != null">limit #{pageNo}, #{pageSize}</if>
    </select>

    <select id="selectAdminCount" resultType="java.lang.Long">
        select count(1) from t_piamom_user_follow f
        left join t_member um on um.id = f.user_id
        left join t_member fm on fm.id = f.follower_id
        <include refid="adminWhere"/>
    </select>

    <select id="selectByPrimaryKey" resultMap="BaseResultMap">
        select f.id, f.user_id, f.follower_id, f.status, f.created_at,
               IFNULL(um.idno, '') AS user_idno, IFNULL(um.nickname, '') AS user_nickname,
               IFNULL(fm.idno, '') AS follower_idno, IFNULL(fm.nickname, '') AS follower_nickname
        from t_piamom_user_follow f
        left join t_member um on um.id = f.user_id
        left join t_member fm on fm.id = f.follower_id
        where f.id = #{id}
    </select>

    <delete id="deleteByPrimaryKey">delete from t_piamom_user_follow where id = #{id}</delete>
</mapper>
