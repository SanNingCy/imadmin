<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.seekweb4.chat.modules.paymentRateConfig.mapper.PaymentRateConfigMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.seekweb4.chat.modules.paymentRateConfig.entity.PaymentRateConfig">
        <id column="id" property="id" />
        <result column="payment_type" property="paymentType" />
        <result column="rate" property="rate" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
        <result column="create_by" property="createBy" />
        <result column="update_by" property="updateBy" />
        <result column="is_deleted" property="isDeleted" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, payment_type, rate, create_time, update_time, create_by, update_by, is_deleted
    </sql>

    <select id="selectByPaymentType" resultType="com.seekweb4.chat.modules.paymentRateConfig.entity.PaymentRateConfig">
        select
        <include refid="Base_Column_List"/>
        from t_payment_rate_config
        where payment_type = #{paymentType} and is_deleted = 0
        limit 1
    </select>

    <!-- 后台管理 - 分页查询费率配置 -->
    <select id="selectAdminPageList" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from t_payment_rate_config
        <where>
            is_deleted = 0
            <if test="id != null">
                and id = #{id}
            </if>
            <if test="paymentType != null">
                and payment_type = #{paymentType}
            </if>
            <if test="rate != null">
                and rate = #{rate}
            </if>
            <if test="createBy != null and createBy != ''">
                and create_by = #{createBy}
            </if>
            <if test="updateBy != null and updateBy != ''">
                and update_by = #{updateBy}
            </if>
        </where>
        <if test="orderBy != null and orderBy != ''">
            order by ${orderBy}
        </if>
        <if test="orderBy == null or orderBy == ''">
            order by create_time desc
        </if>
        <if test="pageNo != null and pageSize != null">
            limit #{pageNo}, #{pageSize}
        </if>
    </select>

    <!-- 后台管理 - 统计费率配置总数 -->
    <select id="selectAdminCount" resultType="java.lang.Long">
        select count(1)
        from t_payment_rate_config
        <where>
            is_deleted = 0
            <if test="id != null">
                and id = #{id}
            </if>
            <if test="paymentType != null">
                and payment_type = #{paymentType}
            </if>
            <if test="rate != null">
                and rate = #{rate}
            </if>
            <if test="createBy != null and createBy != ''">
                and create_by = #{createBy}
            </if>
            <if test="updateBy != null and updateBy != ''">
                and update_by = #{updateBy}
            </if>
        </where>
    </select>

    <!-- 根据主键查询 -->
    <select id="selectByPrimaryKey" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from t_payment_rate_config
        where id = #{id} and is_deleted = 0
    </select>

    <!-- 根据主键选择性更新 -->
    <update id="updateByPrimaryKeySelective" parameterType="com.seekweb4.chat.modules.paymentRateConfig.entity.PaymentRateConfig">
        update t_payment_rate_config
        <set>
            <if test="paymentType != null">
                payment_type = #{paymentType},
            </if>
            <if test="rate != null">
                rate = #{rate},
            </if>
            <if test="createBy != null">
                create_by = #{createBy},
            </if>
            <if test="updateBy != null">
                update_by = #{updateBy},
            </if>
            <if test="isDeleted != null">
                is_deleted = #{isDeleted},
            </if>
            update_time = now()
        </set>
        where id = #{id}
    </update>

    <!-- 插入记录 -->
    <insert id="insert" parameterType="com.seekweb4.chat.modules.paymentRateConfig.entity.PaymentRateConfig">
        insert into t_payment_rate_config (payment_type, rate, create_time, update_time, create_by, update_by, is_deleted)
        values (#{paymentType}, #{rate}, #{createTime}, #{updateTime}, #{createBy}, #{updateBy}, #{isDeleted})
    </insert>

</mapper>