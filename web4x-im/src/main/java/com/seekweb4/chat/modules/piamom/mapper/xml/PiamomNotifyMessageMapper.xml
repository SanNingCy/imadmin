<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.seekweb4.chat.modules.piamom.mapper.PiamomNotifyMessageMapper">

    <resultMap id="BaseResultMap" type="com.seekweb4.chat.modules.piamom.entity.PiamomNotifyMessage">
        <id column="id" property="id"/>
        <result column="receiver_id" property="receiverId"/>
        <result column="from_user_id" property="fromUserId"/>
        <result column="msg_type" property="msgType"/>
        <result column="target_type" property="targetType"/>
        <result column="target_id" property="targetId"/>
        <result column="ref_id" property="refId"/>
        <result column="content" property="content"/>
        <result column="is_read" property="isRead"/>
        <result column="created_at" property="createdAt"/>
        <result column="receiver_idno" property="receiverIdno"/>
        <result column="receiver_nickname" property="receiverNickname"/>
        <result column="from_user_idno" property="fromUserIdno"/>
        <result column="from_user_nickname" property="fromUserNickname"/>
    </resultMap>

    <sql id="adminWhere">
        <where>
            <if test="id != null">and n.id = #{id}</if>
            <if test="receiverId != null and receiverId != ''">and n.receiver_id = #{receiverId}</if>
            <if test="receiverIdno != null and receiverIdno != ''">and rm.idno like concat('%', #{receiverIdno}, '%')</if>
            <if test="fromUserId != null and fromUserId != ''">and n.from_user_id = #{fromUserId}</if>
            <if test="fromUserIdno != null and fromUserIdno != ''">and fm.idno like concat('%', #{fromUserIdno}, '%')</if>
            <if test="msgType != null and msgType != ''">and n.msg_type = #{msgType}</if>
            <if test="targetType != null and targetType != ''">and n.target_type = #{targetType}</if>
            <if test="isRead != null">and n.is_read = #{isRead}</if>
        </where>
    </sql>

    <select id="selectAdminPageList" resultMap="BaseResultMap">
        select n.id, n.receiver_id, n.from_user_id, n.msg_type, n.target_type, n.target_id, n.ref_id,
               n.content, n.is_read, n.created_at,
               IFNULL(rm.idno, '') AS receiver_idno, IFNULL(rm.nickname, '') AS receiver_nickname,
               IFNULL(fm.idno, '') AS from_user_idno, IFNULL(fm.nickname, '') AS from_user_nickname
        from t_piamom_notify_message n
        left join t_member rm on rm.id = n.receiver_id
        left join t_member fm on fm.id = n.from_user_id
        <include refid="adminWhere"/>
        <choose>
            <when test="orderBy != null and orderBy != ''">order by ${orderBy}</when>
            <otherwise>order by n.created_at desc</otherwise>
        </choose>
        <if test="pageNo != null and pageSize != null">limit #{pageNo}, #{pageSize}</if>
    </select>

    <select id="selectAdminCount" resultType="java.lang.Long">
        select count(1) from t_piamom_notify_message n
        left join t_member rm on rm.id = n.receiver_id
        left join t_member fm on fm.id = n.from_user_id
        <include refid="adminWhere"/>
    </select>

    <select id="selectByPrimaryKey" resultMap="BaseResultMap">
        select n.id, n.receiver_id, n.from_user_id, n.msg_type, n.target_type, n.target_id, n.ref_id,
               n.content, n.is_read, n.created_at,
               IFNULL(rm.idno, '') AS receiver_idno, IFNULL(rm.nickname, '') AS receiver_nickname,
               IFNULL(fm.idno, '') AS from_user_idno, IFNULL(fm.nickname, '') AS from_user_nickname
        from t_piamom_notify_message n
        left join t_member rm on rm.id = n.receiver_id
        left join t_member fm on fm.id = n.from_user_id
        where n.id = #{id}
    </select>
</mapper>
